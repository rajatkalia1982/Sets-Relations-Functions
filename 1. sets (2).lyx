\begin_layout Description
Q:
 For the function 
\begin_inset Formula $f\left(x\right)=\dfrac{x}{x+2}$
\end_inset

 ,
 find 
\begin_inset Formula $f\left(x+3\right)$
\end_inset

 ,
 
\begin_inset Formula $f\left(3x\right)$
\end_inset

 ,
\begin_inset Formula $3f\left(x\right)$
\end_inset

 ,
 
\begin_inset Formula $3f\left(3x+3\right)$
\end_inset

 ,
 
\begin_inset Formula $f\left(x^{3}\right)$
\end_inset

 ,
 
\begin_inset Formula $\left(f\left(x\right)\right)^{3}$
\end_inset

 with their respective domains of definition.
\end_layout

\begin_layout Description

\size small
Sol:
 
\begin_inset Formula $f\left(x+3\right)=\dfrac{x+3}{x+5}$
\end_inset

 where 
\begin_inset Formula $x+5\neq0$
\end_inset

 i.e 
\begin_inset Formula $D_{f\left(x+3\right)}=\mathbb{R}-\left\{ -5\right\} $
\end_inset


\end_layout

\begin_layout Description

\size small
\begin_inset Formula $f\left(3x\right)=\dfrac{3x}{3x+2}$
\end_inset

 where 
\begin_inset Formula $3x+2\neq0$
\end_inset

 i.e.
 
\begin_inset Formula $D_{f\left(3x\right)}=\mathbb{R}-\left\{ -\dfrac{2}{3}\right\} $
\end_inset


\end_layout

\begin_layout Description

\size small
\begin_inset Formula $3f\left(x\right)=\dfrac{3x}{x+2}$
\end_inset

 where 
\begin_inset Formula $x+2\neq0$
\end_inset

 i.e.
 
\begin_inset Formula $D_{3f\left(x\right)}=\mathbb{R}-\left\{ -2\right\} $
\end_inset


\end_layout

\begin_layout Description

\size small
\begin_inset Formula $3f\left(3x+3\right)=\dfrac{3x}{3x+5}$
\end_inset

 where 
\begin_inset Formula $3x+5\neq0$
\end_inset

 i.e.
 
\begin_inset Formula $D_{3f\left(3x+3\right)}=\mathbb{R}-\left\{ -\dfrac{5}{3}\right\} $
\end_inset


\end_layout

\begin_layout Description

\size small
\begin_inset Formula $f\left(x^{3}\right)=\dfrac{x^{3}}{x^{3}+2}$
\end_inset

 where 
\begin_inset Formula $x^{3}+2\neq0$
\end_inset

 i.e.
 
\begin_inset Formula $D_{f\left(x^{3}\right)}=\mathbb{R}-\left\{ -\sqrt[3]{2}\right\} $
\end_inset


\end_layout

\begin_layout Description

\size small
\begin_inset Formula $\left(f\left(x\right)\right)^{3}=\left(\dfrac{x}{x+2}\right)^{3}$
\end_inset

 where 
\begin_inset Formula $x+2\neq0$
\end_inset

 i.e.
 
\begin_inset Formula $D_{\left(f\left(x\right)\right)^{3}}=\mathbb{R}-\left\{ -2\right\} $
\end_inset


\end_layout

